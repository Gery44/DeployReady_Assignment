# Normalise line endings to LF in the repository for all text files.
# This prevents the "LF will be replaced by CRLF" warnings on Windows
# and ensures consistent line endings across all contributors and CI runners.
* text=auto eol=lf

# Force shell scripts to always use LF — they will break with CRLF on Linux/macOS.
*.sh text eol=lf

# YAML files (GitHub Actions workflows, docker-compose) must use LF.
*.yml text eol=lf
*.yaml text eol=lf

# Explicitly mark binary files so Git never tries to normalise them.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pem binary
